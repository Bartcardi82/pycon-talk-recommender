application_credential_id     = "your-app-credential-id"
application_credential_secret = "your-app-credential-secret"

ssh_key_name = "your-ssh-key"
api_key      = "choose-a-strong-api-key"

# A100 (80GB, €2.21/hr) — safest for 32B model
vm_flavor = "eg1.a100x1.V12-84"

# A30 (24GB, €0.83/hr) — works with AWQ quantized model, tighter on memory
# vm_flavor = "eg1.a30x1.V8-32"
